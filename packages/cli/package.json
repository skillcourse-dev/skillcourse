{
  "name": "@skillcourse-dev/cli",
  "version": "0.0.1",
  "description": "Authoring CLI for skillcourse: init, validate, bump, quiz init.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skillcourse-dev/skillcourse.git",
    "directory": "packages/cli"
  },
  "homepage": "https://skillcourse.dev",
  "bugs": "https://github.com/skillcourse-dev/skillcourse/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skill-course": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/fix-bin.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "@skillcourse-dev/shared": "workspace:*",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/semver": "^7.5.8",
    "vitest": "^4.1.7"
  }
}
